# LLM 配置
OLLAMA_MODEL=qwen2:7b
OLLAMA_BASE_URL=http://localhost:11434
TEMPERATURE=0.3

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG 参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=4
USE_HYDE=true

# 向量库
VECTORSTORE_PATH=./chroma_db

# 安全（面试演示用）
API_KEY=your-secret-key-2026

# 日志
LOG_LEVEL=INFO